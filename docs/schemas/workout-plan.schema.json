{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workout-app.local/schemas/workout-plan.schema.json",
  "title": "WorkoutPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "planId",
    "name",
    "workouts",
    "moves"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 4
    },
    "planId": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "imageUrl": {
      "type": "string",
      "format": "uri"
    },
    "workoutCompleteSound": {
      "$ref": "#/$defs/customSound"
    },
    "workoutEndedEarlySound": {
      "$ref": "#/$defs/customSound"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "moves": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/move"
      }
    },
    "workouts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workout"
      }
    }
  },
  "$defs": {
    "customSound": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fileName", "mimeType", "base64Data"],
      "properties": {
        "fileName": {"type": "string", "minLength": 1},
        "mimeType": {"type": "string", "enum": ["audio/mpeg", "audio/wav"]},
        "base64Data": {"type": "string", "contentEncoding": "base64"}
      }
    },
    "move": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "moveId",
        "name"
      ],
      "properties": {
        "moveId": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "imageUrl": {
          "type": "string",
          "format": "uri"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "workout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workoutId",
        "title",
        "sets"
      ],
      "properties": {
        "workoutId": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "imageUrl": {
          "type": "string",
          "format": "uri"
        },
        "workoutCompleteSound": {
          "$ref": "#/$defs/customSound"
        },
        "workoutEndedEarlySound": {
          "$ref": "#/$defs/customSound"
        },
        "sets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/set"
          }
        }
      }
    },
    "set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "setId",
        "moves"
      ],
      "properties": {
        "setId": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "lapCount": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "restBetweenLapsSeconds": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "moves": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/workoutMove"
          }
        }
      }
    },
    "workoutMove": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workoutMoveId",
        "moveId",
        "type"
      ],
      "properties": {
        "workoutMoveId": {
          "type": "string",
          "minLength": 1
        },
        "moveId": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "reps",
            "duration",
            "stopwatch"
          ]
        },
        "repCount": {
          "type": "integer",
          "minimum": 1
        },
        "durationSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "prepTimeSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "finishTimeSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "setCount": {
          "type": "integer",
          "minimum": 1
        },
        "repeatEachSide": {
          "type": "boolean"
        },
        "targetWeight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "targetWeightUnit": {
          "type": "string",
          "enum": [
            "kg",
            "lb"
          ]
        },
        "metronomeSpeed": {
          "type": "integer",
          "minimum": 20,
          "maximum": 300
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "reps"
              }
            }
          },
          "then": {
            "required": [
              "repCount"
            ],
            "not": {
              "anyOf": [
                {
                  "required": [
                    "durationSeconds"
                  ]
                },
                {
                  "required": [
                    "metronomeSpeed"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "duration"
              }
            }
          },
          "then": {
            "required": [
              "durationSeconds"
            ],
            "not": {
              "required": [
                "repCount"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "stopwatch"
              }
            }
          },
          "then": {
            "not": {
              "anyOf": [
                {
                  "required": [
                    "repCount"
                  ]
                },
                {
                  "required": [
                    "durationSeconds"
                  ]
                },
                {
                  "required": [
                    "metronomeSpeed"
                  ]
                }
              ]
            }
          }
        }
      ],
      "dependentRequired": {
        "targetWeight": [
          "targetWeightUnit"
        ],
        "targetWeightUnit": [
          "targetWeight"
        ]
      }
    }
  }
}
